{
  "name": "awk",
  "description": "Process text by fields and records. Ideal for columns in logs and CSVs.",
  "synopsis": "awk [OPTION]... 'program' [FILE]...",
  "tags": [
    "text"
  ],
  "examples": [
    {
      "command": "awk '{print $1}' file",
      "description": "Print first field"
    },
    {
      "command": "awk -F: '{print $1}' /etc/passwd",
      "description": "Field separator :"
    },
    {
      "command": "awk 'NR==5' file",
      "description": "Print line 5"
    },
    {
      "command": "awk '{sum+=$1} END {print sum}' nums",
      "description": "Sum first column"
    },
    {
      "command": "ps aux | awk '{print $2, $11}'",
      "description": "PID and command"
    }
  ],
  "options": [
    {
      "flag": "-F fs",
      "description": "Field separator"
    },
    {
      "flag": "-v var=val",
      "description": "Assign variable"
    },
    {
      "flag": "-f progfile",
      "description": "Read program from file"
    }
  ],
  "related": [
    "sed",
    "cut",
    "grep",
    "sort"
  ]
}
