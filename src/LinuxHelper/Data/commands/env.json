{
  "name": "env",
  "description": "With no args, print environment variables. Can run a command with a modified env.",
  "synopsis": "env [OPTION]... [-] [NAME=VALUE]... [COMMAND [ARG]...]",
  "tags": [
    "shell",
    "system"
  ],
  "examples": [
    {
      "command": "env",
      "description": "Print all environment variables"
    },
    {
      "command": "env | grep PATH",
      "description": "Filter variables"
    },
    {
      "command": "env -i HOME=$HOME bash",
      "description": "Clean environment shell"
    },
    {
      "command": "env FOO=bar command",
      "description": "Run with FOO set"
    }
  ],
  "options": [
    {
      "flag": "-i",
      "description": "Start with empty environment"
    },
    {
      "flag": "-u NAME",
      "description": "Remove variable"
    },
    {
      "flag": "-0",
      "description": "End lines with NUL"
    }
  ],
  "related": [
    "export",
    "printenv",
    "set"
  ]
}
