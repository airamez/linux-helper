<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowMissingPrunePackageData>true</AllowMissingPrunePackageData>
    <RootNamespace>LinuxHelper</RootNamespace>
    <AssemblyName>LinuxHelper</AssemblyName>
  </PropertyGroup>

  <!-- Ensure JSON command data is present in build output / publish. -->
  <ItemGroup>
    <Content Update="Data\**\*" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
